# --- Supabase (required for two-device sync; app runs in device-only demo mode without it) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Google recipe search (optional; falls back to TheMealDB, which needs no key) ---
# Create a Programmable Search Engine (cx) + a Custom Search JSON API key.
VITE_GOOGLE_API_KEY=
VITE_GOOGLE_CSE_ID=

# --- Fridge photo recognition (optional; without it, manual entry still works) ---
# Clarifai Personal Access Token (free tier is fine) for the food-item-recognition model.
VITE_CLARIFAI_PAT=
